{
  "name": "__APP_SLUG__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "__APP_DESCRIPTION__",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-feed.mjs all",
    "dev:next": "next dev --turbopack",
    "dev:stripe": "node scripts/dev-feed.mjs all --stripe",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm run test",
    "db:start": "docker compose up -d postgres redis mailpit && npm run db:wait",
    "db:stop": "docker compose down",
    "db:wait": "node scripts/db-wait.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "prisma": "prisma generate",
    "trigger:dev": "npx trigger.dev@latest dev",
    "stripe:listen": "node scripts/stripe-listen.mjs",
    "codex:browser:install": "npx playwright install chromium",
    "codex:browser:auth": "node scripts/codex-browser-auth.mjs",
    "api:dev": "npm run dev --workspace=@__APP_SCOPE__/api",
    "api:build": "npm run build --workspace=@__APP_SCOPE__/api",
    "cli:build": "npm run build --workspace=@__APP_SCOPE__/cli",
    "mcp:dev": "npm run dev --workspace=@__APP_SCOPE__/mcp"
  },
  "dependencies": {
    "@clerk/backend": "latest",
    "@clerk/nextjs": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "latest",
    "@trigger.dev/sdk": "latest",
    "@vercel/analytics": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "latest",
    "react-dom": "latest",
    "sonner": "latest",
    "stripe": "^22.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "playwright": "latest",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "latest",
    "vitest": "^4.1.7"
  }
}
