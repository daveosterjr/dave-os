{
  "name": "dave-os",
  "version": "0.1.0",
  "description": "A personal, open-source app factory for Dave-style Next.js SaaS projects.",
  "license": "MIT",
  "author": "Dave Oster",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daveosterjr/dave-os.git"
  },
  "bugs": {
    "url": "https://github.com/daveosterjr/dave-os/issues"
  },
  "homepage": "https://github.com/daveosterjr/dave-os#readme",
  "keywords": [
    "nextjs",
    "saas",
    "starter",
    "clerk",
    "stripe",
    "prisma",
    "trigger",
    "pusher",
    "mcp",
    "turborepo"
  ],
  "bin": {
    "create-dave-app": "./bin/create-dave-app.mjs",
    "dave-os": "./bin/create-dave-app.mjs"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:generated": "rm -rf /tmp/dave-os-ci-app && node bin/create-dave-app.mjs ci-app --target-dir /tmp/dave-os-ci-app && (cd /tmp/dave-os-ci-app && npm install && npm run typecheck && npm run lint && npm run build) && node tests/smoke-generated-server.mjs /tmp/dave-os-ci-app",
    "verify": "npm test && npm run test:generated",
    "factory:dry": "node bin/create-dave-app.mjs demo-app --dry-run",
    "factory:create": "node bin/create-dave-app.mjs",
    "prepack": "npm run verify"
  },
  "files": [
    "bin",
    "docs",
    "templates",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
